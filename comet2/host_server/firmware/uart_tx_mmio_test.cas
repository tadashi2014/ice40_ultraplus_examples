; UART TX-only MMIO direct test for spi_debug build.
; Sends "HELLO\r\n" by polling #F200 bit1 (TX busy)
; and writing bytes directly to #F202.

MAIN    START
LOOP    OUT     MSG,LEN
        JUMP    LOOP

;SVC1IN  START
;        RET

;SVC2OUT START
;        RET

LEN     DC      7
MSG     DC      'HELLO'
        DC      #000D
        DC      #000A

        END
