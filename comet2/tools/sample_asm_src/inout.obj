NAME:inout
SIZE:0046
START:0020R

0020:              [00001]  ; SVC 1: receive GR2 characters from host into [GR1..]
0020:              [00002]  ; clobbers GR3, GR4
0020:              [00003]  SVC1IN   START
0020:1030-F000     [00004]           LD      GR3,#F000
0022:3030-0061R    [00005]           AND     GR3,ONE
0024:6300-0020R    [00006]           JZE     SVC1IN
0026:              [00007]  
0026:1030-F001     [00008]           LD      GR3,#F001
0028:3030-0063R    [00009]           AND     GR3,MASK8
002A:4030-0064R    [00010]           CPA     GR3,OPIN
002C:6200-003FR    [00011]           JNZ     SVC1DROP
002E:              [00012]  
002E:1030-F002     [00013]           LD      GR3,#F002
0030:3030-0063R    [00014]           AND     GR3,MASK8
0032:1131-0000     [00015]           ST      GR3,0,GR1
0034:1211-0001     [00016]           LAD     GR1,1,GR1
0036:1240-0001     [00017]           LAD     GR4,1
0038:1140-F003     [00018]           ST      GR4,#F003
003A:2120-0061R    [00019]           SUBA    GR2,ONE
003C:6200-0020R    [00020]           JNZ     SVC1IN
003E:8100          [00021]           RET
003F:              [00022]  
003F:1240-0001     [00023]  SVC1DROP LAD     GR4,1
0041:1140-F003     [00024]           ST      GR4,#F003
0043:6400-0020R    [00025]           JUMP    SVC1IN
0045:              [00026]  
0045:              [00027]  ; SVC 2: send GR2 characters from [GR1..] to host
0045:              [00028]  ; clobbers GR3, GR4
0045:              [00029]  SVC2OUT  START
0045:1030-F000     [00030]           LD      GR3,#F000
0047:3030-0062R    [00031]           AND     GR3,TWO
0049:6200-0045R    [00032]           JNZ     SVC2OUT
004B:              [00033]  
004B:1031-0000     [00034]           LD      GR3,0,GR1
004D:3030-0063R    [00035]           AND     GR3,MASK8
004F:5230-0008     [00036]           SLL     GR3,8
0051:3130-0065R    [00037]           OR      GR3,OPOUT
0053:1130-F004     [00038]           ST      GR3,#F004
0055:1240-0000     [00039]           LAD     GR4,0
0057:1140-F005     [00040]           ST      GR4,#F005
0059:1211-0001     [00041]           LAD     GR1,1,GR1
005B:2120-0061R    [00042]           SUBA    GR2,ONE
005D:6200-0045R    [00043]           JNZ     SVC2OUT
005F:8100          [00044]           RET
0060:              [00045]  
0060:              [00046]  BUF      DS      1
0061:0001          [00047]  ONE      DC      1
0062:0002          [00048]  TWO      DC      2
0063:00FF          [00049]  MASK8    DC      #00FF
0064:0010          [00050]  OPIN     DC      #0010
0065:0020          [00051]  OPOUT    DC      #0020
0066:              [00052]  
0066:              [00053]           END
